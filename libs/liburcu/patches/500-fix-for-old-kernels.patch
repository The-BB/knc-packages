--- a/include/urcu/futex.h
+++ b/include/urcu/futex.h
@@ -18,6 +18,11 @@
 
 #if (defined(__linux__) && defined(__NR_futex))
 
+/* __NR_futex_time64 since Linux 5.1 */
+#ifndef LINUX_VERSION_CODE
+#include <linux/version.h>
+#endif
+
 /* For backwards compat */
 # define CONFIG_RCU_HAVE_FUTEX 1
 
@@ -69,17 +74,21 @@ extern int compat_futex_async(int32_t *u
 
 #if (defined(__linux__) && defined(__NR_futex))
 
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5,1,0)
 #ifdef __NR_futex_time64
 # include <linux/time_types.h>
 #endif
+#endif /* __NR_futex_time64 since Linux 5.1 */
 
 static inline int futex(int32_t *uaddr, int op, int32_t val,
 		const struct timespec *timeout, int32_t *uaddr2, int32_t val3)
 {
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(5,1,0)
 #ifdef __NR_futex_time64
 	if (sizeof(struct timespec) == sizeof(struct __kernel_timespec))
 		return syscall(__NR_futex_time64, uaddr, op, val, timeout, uaddr2, val3);
 #endif
+#endif /* __NR_futex_time64 since Linux 5.1 */
 	return syscall(__NR_futex, uaddr, op, val, timeout, uaddr2, val3);
 }
 
